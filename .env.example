# ===========================================
# Weft Klinik-Beschwerde-Analyzer – Environment Configuration
# ===========================================
# Für lokalen Betrieb auf Mac Studio mit Ollama. Keine Cloud-Keys nötig.
# Kopiere zu .env. Human-in-the-Loop und Postgres-Archiv sind zentral.
# LLM-Nodes nutzen direkt http://localhost:11434 (Ollama).

# ----- API Keys (optional für lokalen Modus) -----
# Für Cloud-Dienste (nicht benötigt für Mistral/Qwen via Ollama).
# OPENROUTER_API_KEY=
# TAVILY_API_KEY=
# ELEVENLABS_API_KEY=
# APOLLO_API_KEY=
# DISCORD_BOT_TOKEN=

# ----- Lokale Konfiguration -----
# Ollama ist voreingestellt im Workflow (http://localhost:11434/v1).
# Postgres läuft auf Port 5433 (siehe docker-compose.yml).

# ----- Ports (optional, Defaults) -----
# RESTATE_PORT=8080
# RESTATE_ADMIN_PORT=9070
# WEFT_API_PORT=3000
# DB_PORT=5433  # Angepasst für Klinik-Setup

# ----- Database -----
# Auto-provisioned by dev.sh if not set (Docker required)
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/weft_local

# ----- Logging -----
# RUST_LOG=info

# ----- Security: Credential Encryption -----
# AES-256-GCM key for encrypting trigger credentials in database
# Generate with: openssl rand -base64 32
# If not set, a development key is used (NOT SECURE FOR PRODUCTION)
# CREDENTIAL_ENCRYPTION_KEY=

# ----- Deployment Mode -----
# "local" = standalone mode (localhost origins, no token validation)
# "cloud" = cloud deployment (explicit ALLOWED_ORIGINS, token validation)
DEPLOYMENT_MODE=local

# ----- Security: Rate Limiting -----
# Set to "false" to disable rate limiting (default: enabled)
RATE_LIMIT_ENABLED=true
# Requests per second per IP (default: 200)
RATE_LIMIT_RPS=200
# Burst capacity per IP (default: 5000)
RATE_LIMIT_BURST=5000

# ----- Security: Code Sandbox -----
# Set to "false" to disable sandbox (nsjail). Required in production.
# For local dev without nsjail installed, set to false.
CODE_SANDBOX_ENABLED=false
